# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model settings
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=all-MiniLM-L6-v2

# YOLO
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# API
API_HOST=0.0.0.0
API_PORT=8000

# Vector Store
FAISS_INDEX_PATH=data/vector_store/events.index
EVENTS_METADATA_PATH=data/vector_store/events_metadata.json

# Video
FRAME_CAPTURE_INTERVAL=1.0
VIDEO_SOURCE=0

# RAG
TOP_K_RESULTS=5
MIN_SIMILARITY_SCORE=0.3
